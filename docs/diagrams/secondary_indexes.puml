@startuml SecondaryIndexesArchitecture
!theme plain
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F0F0F0
skinparam classBorderColor #333333

' Define components
package "Database Engine" {

  package "Primary Index (B+Tree)" {
    class PrimaryIndex {
      - root: *Page
      - bufferPool: *BufferPoolManager
      - txnMgr: *TransactionManager
      --
      + Get(primaryKey []byte): ([]byte, error)
      + Put(primaryKey []byte, value []byte): error
      + Delete(primaryKey []byte): error
      + Cursor(): Cursor
    }
  }

  package "Secondary Indexes" {
    class SecondaryIndexManager {
      - indexes: map[string]*SecondaryIndex
      - bufferPool: *BufferPoolManager
      - txnMgr: *TransactionManager
      --
      + CreateIndex(name string, keyLayout []string): error
      + DropIndex(name string): error
      + InsertEntry(indexName string, secKey []byte, rid RID): error
      + DeleteEntry(indexName string, secKey []byte, rid RID): error
      + UpdateEntry(indexName string, oldKey []byte, newKey []byte, rid RID): error
      + Lookup(indexName string, key []byte): ([]RID, error)
      + RangeScan(indexName string, startKey []byte, endKey []byte): ([]RID, error)
    }

    class SecondaryIndex {
      - name: string
      - rootPageID: PageID
      - attributes: []string
      - isUnique: bool
      - btree: *BTree
      --
      + Insert(key []byte, rid RID): error
      + Delete(key []byte, rid RID): error
      + Search(key []byte): ([]RID, error)
      + RangeScan(min []byte, max []byte): ([]RID, error)
      + Get(key []byte): ([]byte, error)
      + UpdateMetadata(): error
    }

    class IndexEntry {
      - secondaryKey: []byte
      - rids: []RID
      --
      + Serialize(): []byte
      + Deserialize(data []byte): error
    }

    class RID {
      - pageID: PageID
      - slotID: SlotID
    }
  }

  package "Storage Layer" {
    class BufferPoolManager {
      - pages: map[PageID]*Page
      - replacer: Replacer
      --
      + FetchPage(pageID PageID): (*Page, error)
      + UnpinPage(pageID PageID, isDirty bool): bool
      + NewPage(): (*Page, error)
      + DeletePage(pageID PageID): bool
    }

    class DiskManager {
      - file: *os.File
      --
      + ReadPage(pageID PageID): ([]byte, error)
      + WritePage(pageID PageID, data []byte): error
      + AllocatePage(): PageID
    }

    class Page {
      - pageID: PageID
      - data: []byte
      - isDirty: bool
      --
      + GetData(): []byte
      + SetData(data []byte): void
    }

    class IndexMetadataPage {
      - indexName: string
      - attributes: []string
      - isUnique: bool
      - rootPageID: PageID
      - createdAt: timestamp
      --
      + Serialize(): []byte
      + Deserialize(data []byte): error
    }
  }

  package "Transaction Management" {
    class TransactionManager {
      - txns: map[TxnID]*Transaction
      - lockMgr: *LockManager
      - walMgr: *WALManager
      --
      + Begin(): TxnID
      + Commit(txnID TxnID): error
      + Abort(txnID TxnID): error
    }

    class LockManager {
      - locks: map[RID]*Lock
      --
      + AcquireLock(rid RID, txnID TxnID, lockMode LockMode): error
      + ReleaseLock(rid RID, txnID TxnID): bool
    }

    class WALManager {
      - logFile: *os.File
      --
      + WriteLog(txnID TxnID, op LogRecord): error
      + Checkpoint(): error
    }
  }
}

' Relationships
PrimaryIndex --> BufferPoolManager : uses
PrimaryIndex --> TransactionManager : uses

SecondaryIndexManager --> SecondaryIndex : manages
SecondaryIndexManager --> TransactionManager : uses
SecondaryIndexManager --> BufferPoolManager : uses

SecondaryIndex --> IndexEntry : stores entries as
SecondaryIndex --> RID : references
SecondaryIndex --> Page : uses B+Tree
SecondaryIndex --> BufferPoolManager : uses
SecondaryIndex --> IndexMetadataPage : updates metadata

IndexEntry --> RID : contains

BufferPoolManager --> Page : manages
BufferPoolManager --> DiskManager : uses
BufferPoolManager --> TransactionManager : coordinates with

TransactionManager --> LockManager : manages
TransactionManager --> WALManager : manages

note right of SecondaryIndex
  Each secondary index maintains:
  - B+Tree structure similar to primary index
  - Maps secondary key -> list of RIDs
  - Supports concurrent access via locks
  - Logged for durability
end note

note right of IndexEntry
  IndexEntry format:
  [SecondaryKey][RIDCount][RID1][RID2]...[RIDN]
  
  Supports:
  - Non-unique indexes (multiple RIDs per key)
  - Unique indexes (single RID per key)
  - Composite keys (multiple attributes)
end note

note right of IndexMetadataPage
  Index metadata stored in system catalog:
  - Index name and type (unique/non-unique)
  - Attributes being indexed
  - Root page ID of the B+Tree
  - Creation timestamp
  - Statistics (optional)
end note

@enduml
